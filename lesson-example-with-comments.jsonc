    {
      "type": "dialogue",
      "subtitle": "Discussing Future Plans",
      "order": 6,
      "dialogue": [
        "Hi Anna, what are you going to do this weekend?",
        "Hi Mark, I’m going to visit my parents in the countryside.",
        "That sounds nice! I’m going to start a new book I bought.",
        "Really? What book are you going to read?",
        "It’s a novel by my favorite author. Are you going to travel soon?",
